{
  "name": "@citation-buddy/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build:prod": "nx run-many --target=build --all --configuration=production",
    "build:bot": "nx run citation-buddy-bot:build:production",
    "build:bot2:prod": "nx run quote-buddy-bot:build:production",
    "build:frontend": "nx run citation-buddy:build:production",
    "start:bot": "nx run citation-buddy-bot:serve",
    "start:bot2": "nx run quote-buddy-bot:serve",
    "start:frontend": "nx run citation-buddy:serve",
    "start:bot:prod": "npm run start:bot -- -c production",
    "start:frontend:prod": "npm run start:frontend -- -c production",
    "start": "concurrently --names \"BOT,FRONTEND\" -c \"bgBlue.bold,bgMagenta.bold\" \"npm run start:bot\" \"npm run start:frontend\"",
    "ngrok": "ngrok http 3000",
    "ngrok:frontend": "ngrok http 4200",
    "docker:run": "docker run -d -p 3000:3000 -v $pwd/.env:/home/node/app/.env -v $pwd/db:/home/node/app/db kingscouter/citation-buddy"
  },
  "private": true,
