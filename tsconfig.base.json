{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "@cite/models": ["./libs/models/src/index.ts"],
      "@quote-buddy/db-json": ["./libs/db-json/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
